# PRODUCTION env for the Moodle backend (Contabo / DigitalOcean / Hetzner / Lightsail).
#
# On the server:
#   cp .env.prod.example .env
#   then replace every <...> placeholder with a real value.
#
# Generate strong passwords with:  openssl rand -base64 24
# NEVER commit the real .env. NEVER reuse the local-dev demo passwords.

# ── Postgres ─────────────────────────────────────────────
POSTGRES_DB=moodle
POSTGRES_USER=moodle
POSTGRES_PASSWORD=<openssl rand -base64 24>

# ── Moodle admin (the web UI login) ──────────────────────
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=<openssl rand -base64 24>
# Real, monitored inbox — Let's Encrypt expiry notices go here too.
MOODLE_ADMIN_EMAIL=admin@ezaytech.co.ke
MOODLE_SITE_NAME=Ezay Tech LMS

# ── Public hostname ──────────────────────────────────────
# The subdomain you point at THIS server's IP via a DNS A record.
# Must match the domain Caddy issues a cert for. No scheme, no trailing slash.
MOODLE_HOST=lms.ezaytech.co.ke
