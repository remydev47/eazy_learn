# Copy to .env in this directory before running `docker compose up -d`
# DO NOT COMMIT .env — it contains the admin password.

# Postgres
POSTGRES_DB=moodle
POSTGRES_USER=moodle
POSTGRES_PASSWORD=change_me_to_something_strong

# Moodle admin (you log in to the Moodle web UI with these)
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=ChangeMe_StrongPass123!
MOODLE_ADMIN_EMAIL=admin@ezaytech.local
MOODLE_SITE_NAME=Ezay Tech LMS

# Hostname Moodle thinks it's served from
# Local dev: localhost
# Production: lms.ezaytech.com (and set MOODLE_HTTP_PORT=80, MOODLE_HTTPS_PORT=443)
MOODLE_HOST=localhost
MOODLE_HTTP_PORT=8080
MOODLE_HTTPS_PORT=8443
